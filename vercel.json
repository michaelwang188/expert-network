{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "env": {
    "DATABASE_URL": "@database_url",
    "NEXTAUTH_<SECRET_REMOVED>",
    "NEXTAUTH_URL": "https://your-app-name.vercel.app"
  },
  "build": {
    "env": {
      "DATABASE_URL": "@database_url",
      "NEXTAUTH_<SECRET_REMOVED>",
      "NEXTAUTH_URL": "https://your-app-name.vercel.app"
    }
  },
  "crons": [
    {
      "path": "/api/cron/health",
      "schedule": "0 9 * * *"
    }
  ]
}
