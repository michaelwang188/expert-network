// Prisma Schema for 产研通 ProLink Expert Network Platform
// Updated for PostgreSQL (Vercel Deployment)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== 用户 =====
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  password    String
  role        Role     @default(RESEARCHER)
  avatar      String?
  orgName     String?
  title       String?
  points      Int       @default(0)   // 公益积分余额
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  expertProfile     Expert?               @relation("UserExpert")
  requests          Request[]             @relation("UserRequests")
  ordersAsRes       Order[]               @relation("OrdersByResearcher")
  pointTransactions PointsTransaction[]   @relation("UserPoints")
  notifications     Notification[]       @relation("UserNotifications")
}

enum Role {
  RESEARCHER
  EXPERT
  ADMIN
}

// ===== 专家档案 =====
model Expert {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation("UserExpert", fields: [userId], references: [id], onDelete: Cascade)

  // 新增字段（C2专家入驻流程）
  sourceChannel  String?   // 来源渠道（wechat/linkedin/referral）
  inviteCode     String?   @unique  // 邀请码
  
  realName      String
  title         String
  org           String
  years         Int
  region        String

  industry1     String
  industry2     String?
  roleType      String
  tags          String
  topics        String

  rateHour      Int
  ratePoints    Int       @default(0)   // 公益积分费率（积分/小时）
  forms         String
  availableTime String?

  idVerified    Boolean  @default(false)
  empVerified   Boolean  @default(false)
  interviewDone Boolean  @default(false)
  complianceSig Boolean  @default(false)
  status        ExpertStatus @default(PENDING)

  completedOrders Int    @default(0)
  rating         Float   @default(0)

  // 三级合规审核
  reviewStatus  ReviewStatus @default(PENDING_REVIEW)
  idCardUrl     String?
  badgeUrl      String?
  employmentProofUrl String?
  reviewedBy    String?
  reviewedAt    DateTime?
  reviewNote    String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关系
  requests   Request[]    @relation("RequestExpert")
  orders     Order[]      @relation("OrdersByExpert")

  @@index([industry1, status])
  @@index([roleType])
}

enum ExpertStatus {
  PENDING
  ACTIVE
  FROZEN
  INACTIVE
}

enum ReviewStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
  INFO_NEEDED
  SUSPENDED
}

// ===== 调研需求 =====
model Request {
  id          String   @id @default(cuid())
  orderNo     String   @unique
  title       String
  industry    String
  subField    String?
  duration    String
  form        String
  budget      String
  timeReq     String?
  outline     String
  forbidden   String?
  status      RequestStatus @default(SUBMITTED)

  researcherId String
  researcher   User     @relation("UserRequests", fields: [researcherId], references: [id])

  // 匹配到的专家（可为空，待匹配）
  expertId    String?
  expert      Expert?  @relation("RequestExpert", fields: [expertId], references: [id])

  order        Order?   @relation("RequestOrder")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, industry])
}

enum RequestStatus {
  SUBMITTED
  COMPLIANCE_OK
  MATCHING
  CONFIRMED
  COMPLETED
  CANCELLED
}

// ===== 订单 =====
model Order {
  id          String   @id @default(cuid())
  orderNo     String   @unique
  requestId   String   @unique
  request     Request  @relation("RequestOrder", fields: [requestId], references: [id])

  researcherId String
  researcher   User     @relation("OrdersByResearcher", fields: [researcherId], references: [id])

  expertId    String?
  expert      Expert?  @relation("OrdersByExpert", fields: [expertId], references: [id])

  interviewTime DateTime?
  amount       Int
  expertFee    Int
  platformFee  Int

  status       OrderStatus @default(PENDING)
  confirmedAt  DateTime?
  completedAt  DateTime?
  paidAt       DateTime?

  outlineApproved Boolean @default(false)
  recordingUrl   String?
  complianceOk   Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([researcherId])
  @@index([expertId])
}

enum OrderStatus {
  PENDING
  PROMO     // 🆕 C3: 新研究员首单0积分
  ACTIVE
  DONE
  PAID
  CANCELLED
}

// ===== 合规记录 =====
model ComplianceLog {
  id          String   @id @default(cuid())
  targetType  String
  targetId    String
  eventType   String
  description String?
  handled     Boolean   @default(false)
  handlerId   String?
  createdAt   DateTime @default(now())

  @@index([targetType, handled])
}

// ===== 公益积分交易记录 =====
model PointsTransaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation("UserPoints", fields: [userId], references: [id])

  amount      Int      // 积分变动量（正数=获得，负数=支出）
  type        PointType
  description String?  // 描述：如"专家访谈完成：芯片设计技术路线调研"
  refId       String?  // 关联的业务ID（订单号/充值单号）
  balance     Int      // 操作后余额

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

enum PointType {
  EARN_LABOR    // 劳动贡献获得（专家完成访谈）
  EARN_CASH     // 现金兑换获得（研究员购买积分）
  SPEND_ORDER   // 订单支出（研究员支付访谈费用）
  ADMIN_ADJUST  // 管理员调整
}

// ===== 通知 =====
model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation("UserNotifications", fields: [userId], references: [id], onDelete: Cascade)
  type      String   // 通知类型：ORDER_ASSIGNED, ORDER_CONFIRMED, etc.
  title     String   // 通知标题
  message   String   // 通知内容
  read      Boolean  @default(false)
  refId     String?  // 关联的业务ID（如订单ID）
  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([createdAt])
}
