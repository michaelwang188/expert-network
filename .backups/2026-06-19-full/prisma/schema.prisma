// Prisma Schema for 产研通 ProLink Expert Network Platform
// Updated for PostgreSQL (Vercel Deployment)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== 用户 =====
model User {
  id          String   @id @default(cuid())
  email       String   @unique
  name        String?
  password    String
  role        Role     @default(RESEARCHER)
  avatar      String?
  orgName     String?
  title       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  expertProfile  Expert?        @relation("UserExpert")
  requests       Request[]      @relation("UserRequests")
  ordersAsRes    Order[]        @relation("OrdersByResearcher")
}

enum Role {
  RESEARCHER
  EXPERT
  ADMIN
}

// ===== 专家档案 =====
model Expert {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation("UserExpert", fields: [userId], references: [id], onDelete: Cascade)

  realName      String
  title         String
  org           String
  years         Int
  region        String

  industry1     String
  industry2     String?
  roleType      String
  tags          String
  topics        String

  rateHour      Int
  forms         String
  availableTime String?

  idVerified    Boolean  @default(false)
  empVerified   Boolean  @default(false)
  interviewDone Boolean  @default(false)
  complianceSig Boolean  @default(false)
  status        ExpertStatus @default(PENDING)

  completedOrders Int    @default(0)
  rating         Float   @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // 关系
  requests   Request[]    @relation("RequestExpert")
  orders     Order[]      @relation("OrdersByExpert")

  @@index([industry1, status])
  @@index([roleType])
}

enum ExpertStatus {
  PENDING
  ACTIVE
  FROZEN
  INACTIVE
}

// ===== 调研需求 =====
model Request {
  id          String   @id @default(cuid())
  orderNo     String   @unique
  title       String
  industry    String
  subField    String?
  duration    String
  form        String
  budget      String
  timeReq     String?
  outline     String
  forbidden   String?
  status      RequestStatus @default(SUBMITTED)

  researcherId String
  researcher   User     @relation("UserRequests", fields: [researcherId], references: [id])

  // 匹配到的专家（可为空，待匹配）
  expertId    String?
  expert      Expert?  @relation("RequestExpert", fields: [expertId], references: [id])

  order        Order?   @relation("RequestOrder")

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status, industry])
}

enum RequestStatus {
  SUBMITTED
  COMPLIANCE_OK
  MATCHING
  CONFIRMED
  COMPLETED
  CANCELLED
}

// ===== 订单 =====
model Order {
  id          String   @id @default(cuid())
  orderNo     String   @unique
  requestId   String   @unique
  request     Request  @relation("RequestOrder", fields: [requestId], references: [id])

  researcherId String
  researcher   User     @relation("OrdersByResearcher", fields: [researcherId], references: [id])

  expertId    String?
  expert      Expert?  @relation("OrdersByExpert", fields: [expertId], references: [id])

  interviewTime DateTime?
  amount       Int
  expertFee    Int
  platformFee  Int

  status       OrderStatus @default(PENDING)
  confirmedAt  DateTime?
  completedAt  DateTime?
  paidAt       DateTime?

  outlineApproved Boolean @default(false)
  recordingUrl   String?
  complianceOk   Boolean  @default(false)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([status])
  @@index([researcherId])
  @@index([expertId])
}

enum OrderStatus {
  PENDING
  ACTIVE
  DONE
  PAID
  CANCELLED
}

// ===== 合规记录 =====
model ComplianceLog {
  id          String   @id @default(cuid())
  targetType  String
  targetId    String
  eventType   String
  description String?
  handled     Boolean   @default(false)
  handlerId   String?
  createdAt   DateTime @default(now())

  @@index([targetType, handled])
}
